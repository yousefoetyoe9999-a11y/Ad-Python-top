import pandas as pd
from sklearn.feature_selection import VarianceThreshold

df = pd.read_csv('data/day24_selection.csv')

X = df.drop('target', axis=1)
y = df['target']

print("Before selection:")
print(f"Features: {X.shape[1]}")
print(f"Columns: {X.columns.tolist()}")

vt = VarianceThreshold(threshold=0.01)
X_var = vt.fit_transform(X)
selected_cols = X.columns[vt.get_support()].tolist()

print(f"\nAfter variance threshold:")
print(f"Features: {len(selected_cols)}")
print(f"Removed: {set(X.columns) - set(selected_cols)}")

df_filtered = df[selected_cols + ['target']]

corr_matrix = df_filtered.drop('target', axis=1).corr().abs()
upper = corr_matrix.where(pd.np.triu(pd.np.ones(corr_matrix.shape), k=1).astype(bool))
to_drop = [col for col in upper.columns if any(upper[col] > 0.9)]

print(f"\nHighly correlated features (>0.9): {to_drop}")

df_final = df_filtered.drop(columns=to_drop)

print(f"\nAfter removing correlations:")
print(f"Features: {df_final.shape[1] - 1}")
print(f"Final columns: {df_final.drop('target', axis=1).columns.tolist()}")
